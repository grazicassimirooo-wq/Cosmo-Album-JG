rules_version = '2';

// Regras do Álbum J&G.
// O app não tem login (é um presente compartilhado por link), então leitura e
// escrita ficam liberadas — mas SÓ nas coleções que o álbum realmente usa.
// Isso substitui o "modo de teste" (que expira em 30 dias e derruba a
// sincronização) e impede que gravem dados em coleções arbitrárias.
// Endurecimento futuro: Firebase Anonymous Auth + App Check.
service cloud.firestore {
  match /databases/{database}/documents {
    match /{col}/{doc} {
      allow read, write: if col in [
        'counters',        // contadores das figurinhas
        'doce-pedido',     // pedido de doce em tempo real
        'doces',           // doces enviados
        'fidelidade',      // selos do cartão fidelidade (Cap V) — Fase 2/3
        'letters',         // cartas de amor
        'photos',          // fotos do álbum (doc guarda URL do Storage)
        'places',          // lugares
        'pote-bilhetes',   // bilhetes que uma escreve pra outra ler no pote (Fase 5) — {by, texto, ts}
        'pote-log',        // aberturas diárias do pote de recadinhos (Cap I) — Fase 3
        'presence',        // presença "estou aqui"
        'presence-status', // online/visto por último (estilo WhatsApp)
        'profiles',        // perfis J & G
        'push-log',        // diagnóstico dos envios de push (escrito pela função)
        'quiz-linguagem',  // resultado do quiz
        'reactions',       // reações
        'secreto-log',     // visitas ao caderno secreto (Cap VI) — só timestamp, sem conteúdo — Fase 3
        'serviceMedia',    // mídia do capítulo serviço
        'services',        // atos de serviço
        'tempo-diario',    // diário do tempo de qualidade
        'tokens',          // tokens de push (FCM)
        'touchMedia',      // mídia do capítulo toque
        'touches',         // toques
        'videos',          // vídeos (doc guarda URL do Storage)
        'visits'           // visitas aos 6 cadernos (Fase 4) — {who, cap, ts}
      ];
    }
  }
}
